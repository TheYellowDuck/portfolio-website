# Copy this file to `.env` and fill in the value. `.env` is gitignored, so your
# real token is never committed. This is only for running `npm run sync:github`
# LOCALLY — the scheduled GitHub Action uses GitHub's built-in token and needs none.
#
# Create a token at: GitHub → Settings → Developer settings → Fine-grained tokens
#   • Repository access: Public repositories (read-only)  ← least privilege
#   • Expiration: short (e.g. 30 days)
# NEVER prefix it with NEXT_PUBLIC_ (that would expose it to the browser).

GH_TOKEN=
